    setLoading(false);
  }
});

const { data: listener } = supabase.auth.onAuthStateChange((_event, session) => {
  setSession(session ?? null);
});

return () => {
  mounted = false;
  listener.subscription.unsubscribe();
};

}, []);

const userEmail = useMemo(() => session?.user?.email || "guest@demo.app", [session]);

