        </Card>
      </div>

      <div className="space-y-6">
        <Card className="rounded-3xl border-0 shadow-sm">
          <CardHeader>
            <CardTitle>Quick Actions</CardTitle>
          </CardHeader>
          <CardContent className="space-y-3">
            <Button className="w-full rounded-xl justify-start"><Phone className="w-4 h-4 mr-2" /> Add Customer</Button>
            <Button variant="outline" className="w-full rounded-xl justify-start"><Wallet className="w-4 h-4 mr-2" /> Record Payment</Button>
