                <Input type="password" placeholder="Create password" value={password} onChange={(e) => setPassword(e.target.value)} />
                <Button className="w-full rounded-xl" onClick={handleAuth}>Create Account</Button>
              </TabsContent>
            </Tabs>

            {message ? (
              <div className="mt-4 text-sm rounded-xl bg-slate-100 px-4 py-3 text-slate-700">{message}</div>
            ) : null}
          </CardContent>
        </Card>
