    </div>
  </div>
);

}

return ( <div className="min-h-screen bg-slate-100 p-4 md:p-8"> <div className="max-w-7xl mx-auto space-y-8"> <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4"> <div> <Badge className="rounded-full mb-3">Business Dashboard</Badge> <h1 className="text-3xl md:text-4xl font-black text-slate-900">Tony Rich Data Express</h1> <p className="text-slate-600 mt-2">Manage sales, packages, users, and top-ups from one place.</p> </div> <div className="flex gap-3 flex-wrap"> <Badge variant="secondary" className="rounded-full px-4 py-2"> <User className="w-4 h-4 mr-2" /> {userEmail} </Badge> <Button variant="outline" className="rounded-xl" onClick={handleLogout}> <LogOut className="w-4 h-4 mr-2" /> Logout </Button> </div> </div>

